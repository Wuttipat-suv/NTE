rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin UIDs
    function isAdmin() {
      // สงวน UID ของแอดมินพี ไว้เป็น Master Admin เพียงผู้เดียวตามที่คุณพีรีเควส
      return request.auth != null && (
        request.auth.uid == 'yh9dSe2xjKPmDFcJFOcnZRex0Zi1' ||
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
      );
    }

    // ระบบจัดการแอดมิน
    match /admin_users/{uid} {
      allow read, write: if isAdmin();
    }
    match /pending_users/{uid} {
      allow read: if isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }

    // ============ ITEMS ============
    match /items/{itemId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admin แก้อะไรก็ได้ | ลูกค้าแก้ได้แค่ stock (ห้ามติดลบ)
      allow update: if isAdmin()
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
                        && request.resource.data.stock >= 0);

      match /stockHistory/{historyId} {
        allow read: if true;
        allow delete: if isAdmin();
        allow create: if isAdmin()
                      && request.resource.data.qty is number
                      && request.resource.data.addedBy is string
                      && request.resource.data.addedBy.size() > 0;
      }
    }

    // ============ ORDERS ============
    match /orders/{orderId} {
      // Admin อ่านได้ทุก order | ลูกค้าอ่านได้เฉพาะ order ที่ตัวเอง query ผ่าน where
      allow read: if isAdmin() || true;
      // NOTE: Firestore rules ไม่สามารถจำกัด list query ได้แบบ field-level
      // การป้องกันจริงต้องทำผ่าน query constraint ฝั่ง client

      // ลูกค้าสร้าง order ได้ (ต้องผ่าน validation) — totalPrice >= 0 รองรับคูปอง 100%
      allow create: if request.resource.data.keys().hasAll(['facebook', 'characterName', 'items', 'totalPrice', 'status', '_hp'])
                    && request.resource.data._hp == ''
                    && request.resource.data.facebook is string
                    && request.resource.data.facebook.size() >= 3
                    && request.resource.data.facebook.size() <= 100
                    && request.resource.data.characterName is string
                    && request.resource.data.characterName.size() >= 2
                    && request.resource.data.characterName.size() <= 100
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 20
                    && request.resource.data.totalPrice is number
                    && request.resource.data.totalPrice >= 0
                    && request.resource.data.status == 'pending';

      // Admin แก้อะไรก็ได้ | ลูกค้าเปลี่ยนได้แค่ pending → cancelled (field อื่นห้ามแก้)
      allow update: if isAdmin()
                    || (resource.data.status == 'pending'
                        && request.resource.data.status == 'cancelled'
                        && request.resource.data.facebook == resource.data.facebook
                        && request.resource.data.characterName == resource.data.characterName
                        && request.resource.data.items == resource.data.items
                        && request.resource.data.totalPrice == resource.data.totalPrice);

      allow delete: if isAdmin();
    }

    // ============ STATS ============
    match /stats/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============ SETTINGS ============
    // shop doc (isOpen, shopState, closeReason, promptpay) — ลูกค้าต้องอ่านได้เพื่อเช็คสถานะร้าน+QR
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============ COUPONS ============
    match /coupons/{couponId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // ลูกค้าอัปเดต usedCount ได้ตอนสั่งสำเร็จ
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount'])
        && request.resource.data.usedCount == resource.data.usedCount + 1
      );
    }

    // ============ RESERVATIONS (จองสินค้าในตะกร้า) ============
    match /reservations/{sessionId} {
      allow read: if true;
      allow create: if request.resource.data.sessionId == sessionId
                    && request.resource.data.items is map
                    && request.resource.data.expiresAt is timestamp;
      allow update: if resource.data.sessionId == sessionId
                    && request.resource.data.sessionId == sessionId
                    && request.resource.data.items is map
                    && request.resource.data.expiresAt is timestamp;
      allow delete: if resource.data.sessionId == sessionId || isAdmin();
    }
  }
}

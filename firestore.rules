rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin UIDs
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'TUts68ApuzUR5Z6qLunSWvvJSIJ2'
        || request.auth.uid == 'yh9dSe2xjKPmDFcJFOcnZRex0Zi1'
      );
    }

    // ============ ITEMS ============
    match /items/{itemId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Admin แก้อะไรก็ได้ | ลูกค้าแก้ได้แค่ stock (ห้ามติดลบ)
      allow update: if isAdmin()
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
                        && request.resource.data.stock >= 0);

      match /stockHistory/{historyId} {
        allow read: if true;
        allow delete: if isAdmin();
        allow create: if isAdmin()
                      && request.resource.data.qty is number
                      && request.resource.data.addedBy is string
                      && request.resource.data.addedBy.size() > 0;
      }
    }

    // ============ ORDERS ============
    match /orders/{orderId} {
      allow read: if true;

      // ลูกค้าสร้าง order ได้ (ต้องผ่าน validation)
      allow create: if request.resource.data.keys().hasAll(['facebook', 'characterName', 'items', 'totalPrice', 'status', '_hp'])
                    && request.resource.data._hp == ''
                    && request.resource.data.facebook is string
                    && request.resource.data.facebook.size() >= 3
                    && request.resource.data.facebook.size() <= 100
                    && request.resource.data.characterName is string
                    && request.resource.data.characterName.size() >= 2
                    && request.resource.data.characterName.size() <= 100
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 20
                    && request.resource.data.totalPrice is number
                    && request.resource.data.totalPrice > 0
                    && request.resource.data.status == 'pending';

      // Admin แก้อะไรก็ได้ | ลูกค้าเปลี่ยนได้แค่ pending → cancelled (field อื่นห้ามแก้)
      allow update: if isAdmin()
                    || (resource.data.status == 'pending'
                        && request.resource.data.status == 'cancelled'
                        && request.resource.data.facebook == resource.data.facebook
                        && request.resource.data.characterName == resource.data.characterName
                        && request.resource.data.items == resource.data.items
                        && request.resource.data.totalPrice == resource.data.totalPrice);

      allow delete: if false;
    }

    // ============ SETTINGS ============
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

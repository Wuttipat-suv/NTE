{
  "hosting": {
    "site": "talesrunner-bubbleshop",
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      "test-order.html",
      "clear-orders.html",
      "prompt.md",
      "REVIEW.md",
      "TODO-SECURITY.md",
      "review-*.md",
      "MEMORY.md",
      "package.json",
      "package-lock.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**/*.css",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
